rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName
    //
    // Collection: pets
    // Fields: id, ownerId, tagId, name, breed, description, ownerPhone, ownerAddress, photoUrl, createdAt
    //
    // Collection: tags
    // Fields: id, petId, ownerId, activated
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ennesruan@gmail.com" && request.auth.token.email_verified == true);
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Owners
    match /owners/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Pets
    match /pets/{petId} {
      // Anyone can read a pet profile (for the finder page)
      allow read: if true;
      
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerId == request.auth.uid &&
                      request.resource.data.name.size() > 0 &&
                      request.resource.data.name.size() < 100;
                      
      allow update: if isDocOwner() && 
                      request.resource.data.ownerId == resource.data.ownerId;
                      
      allow delete: if isDocOwner();
    }

    // Tags
    match /tags/{tagId} {
      // Anyone can read a tag to see if it's active
      allow read: if true;
      
      // Activation logic: a tag can be updated if it's not activated yet or by the owner
      allow update: if isAuthenticated() && (
        (!resource.data.activated) || 
        (resource.data.ownerId == request.auth.uid)
      );
      
      // Admin only for creation of new tags in the registry
      allow create: if isAdmin(); 
    }

    // Reminders
    match /reminders/{reminderId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Adoption Pets
    match /adoption_pets/{petId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Simplified for now
      allow delete: if isAuthenticated();
    }

    // Lost Alerts (SOS)
    match /lost_alerts/{alertId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Walks
    match /walks/{walkId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Posts
    match /posts/{postId} {
      allow read: if true; // Public feed
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
